{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{"type": "host", "value": "www.agentdebrief.com"}],
      "destination": "https://agentdebrief.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/lead",
      "destination": "/lead/index.html"
    },
    {
      "source": "/blog",
      "destination": "/blog/index.html"
    },
    {
      "source": "/blog/(.*)",
      "destination": "/blog/$1.html"
    }
  ]
}
